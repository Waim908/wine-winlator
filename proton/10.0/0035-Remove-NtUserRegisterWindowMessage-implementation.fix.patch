+-    status = NtQueryInformationAtom( atom, AtomBasicInformation, abi, sizeof(abi_buf), NULL );
+-    todo_wine ok( status == STATUS_INVALID_HANDLE, "got %#lx\n", status );
+-
+-    memset( buf, 0xcc, sizeof(buf) );
