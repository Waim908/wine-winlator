From 2e8d85cc51acc3a794c0cf47aa08ca7abab91e5d Mon Sep 17 00:00:00 2001
From: BrunoSX <brunodeveloper85@gmail.com>
Date: Sat, 1 Nov 2025 16:25:34 -0300
Subject: [PATCH 37/40] mmdevapi: Add implementations from Wine upstream

---
 dlls/mmdevapi/devenum.c  |  5 +++++
 programs/winecfg/audio.c | 11 ++++++++---
 2 files changed, 13 insertions(+), 3 deletions(-)

diff --git a/dlls/mmdevapi/devenum.c b/dlls/mmdevapi/devenum.c
index adce05d..d147d24 100755
--- a/dlls/mmdevapi/devenum.c
+++ b/dlls/mmdevapi/devenum.c
@@ -543,6 +543,11 @@ static MMDevice *MMDevice_Create(const WCHAR *name, GUID *id, EDataFlow flow, DW
                 PropVariantClear(&pv2);
             }
 
+            pv.vt = VT_LPWSTR;
+            pv.pwszVal = drvs.module_name;
+
+            MMDevice_SetPropValue(id, flow, (const PROPERTYKEY*)&DEVPKEY_Device_Driver, &pv);
+
             RegCloseKey(keyprop);
         }
         RegCloseKey(key);
diff --git a/programs/winecfg/audio.c b/programs/winecfg/audio.c
index b98efbc..b0fa6e8 100755
--- a/programs/winecfg/audio.c
+++ b/programs/winecfg/audio.c
@@ -184,12 +184,15 @@ static BOOL get_driver_name(IMMDeviceEnumerator *devenum, PROPVARIANT *pv)
     IPropertyStore *ps;
     HRESULT hr;
 
-    hr = IMMDeviceEnumerator_GetDevice(devenum, L"Wine info device", &device);
-    if(FAILED(hr))
+    hr = IMMDeviceEnumerator_GetDefaultAudioEndpoint(devenum, eRender, eConsole, &device);
+    if(FAILED(hr)) {
+        ERR("Could not get default audio endpoint.\n");
         return FALSE;
+    }
 
     hr = IMMDevice_OpenPropertyStore(device, STGM_READ, &ps);
     if(FAILED(hr)){
+        ERR("Could not get property store for default audio endpoint (0x%p).\n", device);
         IMMDevice_Release(device);
         return FALSE;
     }
@@ -198,8 +201,10 @@ static BOOL get_driver_name(IMMDeviceEnumerator *devenum, PROPVARIANT *pv)
             (const PROPERTYKEY *)&DEVPKEY_Device_Driver, pv);
     IPropertyStore_Release(ps);
     IMMDevice_Release(device);
-    if(FAILED(hr))
+    if(FAILED(hr) || pv == NULL || pv->pwszVal == NULL) {
+        ERR("Could not get device driver property value.\n");
         return FALSE;
+    }
 
     return TRUE;
 }
