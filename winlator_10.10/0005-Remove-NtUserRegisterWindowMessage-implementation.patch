-    RtlInitUnicodeString( &str, name );
-    return NtUserRegisterWindowMessage( &str );
+    UINT ret = GlobalAddAtomW(str);
+    TRACE("%s ret=%x\n", debugstr_w(str), ret);
+    return ret;
 }
 
